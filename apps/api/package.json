{
  "name": "@studio/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format esm --platform node --clean --sourcemap",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --root ../.. apps/api/src"
  },
  "dependencies": {
    "@studio/contracts": "0.1.0",
    "@decartai/sdk": "0.1.14",
    "@fastify/helmet": "13.1.0",
    "@fastify/static": "10.1.0",
    "dotenv": "17.4.2",
    "fastify": "5.10.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "tsup": "8.5.1",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
