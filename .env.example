# Server-only Decart credential used to mint short-lived browser tokens.
DECART_API_KEY=

# Optional server-only OpenAI prompt optimization and GPT Image generation for Lucy 2.5
# character references. The browser never receives this credential.
OPENAI_API_KEY=
OPENAI_PROMPT_OPTIMIZER_MODEL=gpt-5.6
OPENAI_PROMPT_OPTIMIZER_REASONING=medium
OPENAI_PROMPT_OPTIMIZER_VERSION=lucy-character-reference-v1
OPENAI_REFERENCE_IMAGE_MODEL=gpt-image-2
OPENAI_REFERENCE_IMAGE_QUALITY=high

# Durable generated-reference storage. Relative paths resolve from the process working directory.
LIGHTFRAME_DATA_DIR=./.lightframe-data

# Optional ElevenLabs integration. Local capture and local effects work without it.
ELEVENLABS_API_KEY=
ELEVENLABS_STS_MODEL_ID=eleven_multilingual_sts_v2
# Strict boolean forwarded to speech-to-speech conversion. False requests zero retention and
# currently requires an eligible ElevenLabs enterprise account; choose true only after reviewing
# the provider retention terms for the configured workspace.
ELEVENLABS_ENABLE_LOGGING=false

# Client-visible Guided experience rollout. `all` makes Guided the default at `/`;
# use `opt-in` to require `/guided` (or `?characterFlow=guided`) and `off` to route to Advanced.
VITE_CHARACTER_FLOW_ROLLOUT=all

# Loopback API port and validated runtime mode.
PORT=4100
NODE_ENV=development
