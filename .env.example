# Server-only Decart credential used to mint short-lived browser tokens.
DECART_API_KEY=

# Optional ElevenLabs integration. Local capture and local effects work without it.
ELEVENLABS_API_KEY=
ELEVENLABS_STS_MODEL_ID=eleven_multilingual_sts_v2
# Strict boolean forwarded to speech-to-speech conversion. False requests zero retention and
# currently requires an eligible ElevenLabs enterprise account; choose true only after reviewing
# the provider retention terms for the configured workspace.
ELEVENLABS_ENABLE_LOGGING=false

# Loopback API port and validated runtime mode.
PORT=4100
NODE_ENV=development
